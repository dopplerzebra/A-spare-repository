        } else {
            playerStats.rank = 0; // 庶妃
        }
    }
    
    // 渲染场景
    function renderScene(sceneId) {
        currentSceneId = sceneId;
        const scene = story[sceneId];
        
        if (!scene) {
            console.error("场景不存在:", sceneId);
            // 如果场景不存在，跳转到起始场景
            renderScene('start');
            return;
        }
        
        // 检查是否触发结局
        const ending = checkForEnding();
        if (ending && story[ending]) {
            showEnding(ending);
            return;
        }
        
        document.getElementById('story-text').textContent = scene.text;
        const choiceContainer = document.getElementById('choices');
        choiceContainer.innerHTML = '';
        
        if (scene.type === "ending") {
            showEnding(sceneId);
            return;
        }
        
        if (scene.choices && scene.choices.length > 0) {
            scene.choices.forEach(choice => {
                const btn = document.createElement('button');
                btn.className = 'choice-btn';
                btn.innerHTML = `<span>${choice.text}</span>`;
                btn.onclick = () => handleChoice(choice);
                choiceContainer.appendChild(btn);
            });
        } else {
            // 如果没有选项，显示重新开始按钮
            const btn = document.createElement('button');
            btn.className = 'choice-btn';
            btn.innerHTML = '<span>重新开始游戏</span>';
            btn.onclick = () => {
                resetGame();
                renderScene('start');
            };
            choiceContainer.appendChild(btn);
        }
        
        updateStatsDisplay();
    }
    
    // 处理选择
    function handleChoice(choice) {
        // 更新属性
        playerStats.lawScore = Math.max(0, Math.min(100, playerStats.lawScore + choice.lawEffect));
        playerStats.moralScore = Math.max(0, Math.min(100, playerStats.moralScore + choice.moralEffect));
        playerStats.sceneCount++;
        
        // 更新位分
        updateRank();
        
        // 显示反馈
        showFeedback(choice);
    }
    
    // 显示反馈
    function showFeedback(choice) {
        const overlay = document.getElementById('feedback-overlay');
        const title = document.getElementById('feedback-title');
        const law = document.getElementById('law-content');
        const actionBtn = document.getElementById('action-btn');
        
        // 根据选择影响设置反馈标题
        if (choice.lawEffect > 0 && choice.moralEffect > 0) {
            title.textContent = "✅ 德法兼备";
            title.style.color = "var(--success)";
        } else if (choice.lawEffect < 0 && choice.moralEffect < 0) {
            title.textContent = "⚠️ 德法两失";
            title.style.color = "var(--danger)";
        } else if (choice.lawEffect > 0 && choice.moralEffect < 0) {
            title.textContent = "⚖️ 法理为上";
            title.style.color = "var(--palace-blue)";
        } else if (choice.lawEffect < 0 && choice.moralEffect > 0) {
            title.textContent = "💖 情理为先";
            title.style.color = "var(--warning)";
        } else {
            title.textContent = "➡️ 平波无澜";
            title.style.color = "var(--palace-brown)";
        }
        
        law.textContent = choice.law;
        
        // 确定下一个场景
        let nextScene = choice.next;
        
        // 如果next是一个函数，执行它以获取实际的下一个场景
        if (typeof nextScene === 'function') {
            nextScene = getNextSceneBasedOnStats(nextScene);
        }
        
        // 确保下一个场景存在
        if (!story[nextScene]) {
            console.error("下一个场景不存在:", nextScene);
            nextScene = 'start';
        }
        
        actionBtn.onclick = () => {
            overlay.style.display = 'none';
            renderScene(nextScene);
        };
        
        overlay.style.display = 'flex';
    }
    
    // 显示结局
    function showEnding(endingId) {
        const ending = story[endingId];
        if (!ending) {
            console.error("结局不存在:", endingId);
            return;
        }
        
        const endingScreen = document.getElementById('ending-screen');
        const endingSeal = document.getElementById('ending-seal');
        const endingTitle = document.getElementById('ending-title');
        const endingText = document.getElementById('ending-text');
        const endingLaw = document.getElementById('ending-law');
        const restartBtn = document.getElementById('restart-btn');
        
        // 设置结局内容
        endingTitle.textContent = ending.title;
        endingText.textContent = ending.text;
        endingLaw.textContent = ending.law;
        
        // 设置结局印章
        if (endingId.includes('imperial_advisor')) {
            endingSeal.textContent = "⚖️";
            endingSeal.style.background = "linear-gradient(135deg, var(--palace-blue), var(--palace-gold))";
        } else if (endingId.includes('royal_favor')) {
            endingSeal.textContent = "👑";
            endingSeal.style.background = "linear-gradient(135deg, var(--palace-gold), var(--palace-red))";
        } else if (endingId.includes('disgrace') || endingId.includes('exile')) {
            endingSeal.textContent = "🔒";
            endingSeal.style.background = "linear-gradient(135deg, #666, #333)";
        } else {
            endingSeal.textContent = "🍂";
            endingSeal.style.background = "linear-gradient(135deg, var(--palace-green), var(--palace-brown))";
        }
        
        // 隐藏选择按钮
        document.getElementById('choices').innerHTML = '';
        endingScreen.style.display = 'flex';
        
        // 添加滚动到顶部的功能
        endingScreen.scrollTop = 0;
    }
    
    // 重置游戏
    function resetGame() {
        playerStats = {
            lawScore: 50,
            moralScore: 50,
            rank: 0,
            sceneCount: 1
        };
    }
    
    // 初始化游戏
    document.addEventListener('DOMContentLoaded', () => {
        // 绑定重启按钮事件
        document.getElementById('restart-btn').onclick = function() {
            resetGame();
            document.getElementById('ending-screen').style.display = 'none';
            renderScene('start');
        };
        
        // 开始游戏
        renderScene('start');
    });
</script>

</body>
</html>
