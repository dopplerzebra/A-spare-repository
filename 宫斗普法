<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>深宫普法传：凤仪天下</title>
    <style>
        :root {
            --palace-red: #8b1a1a;
            --palace-gold: #d4af37;
            --palace-beige: #f5f0e6;
            --palace-brown: #8b4513;
            --palace-blue: #2c5f8a;
            --palace-green: #556b2f;
            --success: #2e8b57;
            --warning: #daa520;
            --danger: #8b0000;
        }
        
        * {
            box-sizing: border-box;
        }
        
        body {
            font-family: 'STKaiti', '楷体', 'SimSun', serif;
            background-color: #3a2615;
            background-image: linear-gradient(rgba(58, 38, 21, 0.9), rgba(58, 38, 21, 0.9)), 
                            url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 100 100"><path d="M0,0 L100,0 L100,100 L0,100 Z" fill="none" stroke="%235a3c1a" stroke-width="2"/><path d="M20,20 L80,20 L80,80 L20,80 Z" fill="none" stroke="%235a3c1a" stroke-width="1"/></svg>');
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            padding: 20px;
            color: #3a2615;
        }
        
        #game-container {
            background: var(--palace-beige);
            width: 100%;
            max-width: 700px;
            padding: 25px 30px 30px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
            border: 8px double var(--palace-red);
            position: relative;
            overflow: hidden;
        }
        
        #game-container::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 8px;
            background: linear-gradient(90deg, var(--palace-red), var(--palace-gold), var(--palace-red));
        }
        
        h1 {
            color: var(--palace-red);
            text-align: center;
            border-bottom: 3px double var(--palace-gold);
            padding-bottom: 15px;
            margin: 0 0 20px;
            font-size: 2.2rem;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.1);
            letter-spacing: 2px;
        }
        
        .subtitle {
            text-align: center;
            color: var(--palace-brown);
            font-size: 0.9rem;
            margin-top: -10px;
            margin-bottom: 20px;
            font-style: italic;
        }
        
        #stats-bar {
            display: flex;
            justify-content: space-between;
            background: linear-gradient(to right, #e8dfca, #d8c9a9);
            border: 2px solid var(--palace-brown);
            border-radius: 8px;
            padding: 10px 15px;
            margin-bottom: 20px;
            font-size: 0.9rem;
        }
        
        .stat-item {
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        
        .stat-value {
            font-weight: bold;
            font-size: 1.2rem;
            color: var(--palace-red);
        }
        
        .stat-label {
            font-size: 0.8rem;
            color: var(--palace-brown);
        }
        
        #scene-container {
            position: relative;
            min-height: 200px;
        }
        
        #scene-decoration {
            position: absolute;
            top: 0;
            right: 0;
            width: 80px;
            height: 100%;
            background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 200"><path d="M50,10 C60,5 80,10 80,30 C80,50 50,80 50,80 C50,80 20,50 20,30 C20,10 40,5 50,10 Z" fill="%23d4af37" opacity="0.3"/><path d="M50,100 C60,95 80,100 80,120 C80,140 50,170 50,170 C50,170 20,140 20,120 C20,100 40,95 50,100 Z" fill="%238b1a1a" opacity="0.2"/></svg>');
            background-repeat: no-repeat;
            background-position: right top;
            opacity: 0.6;
        }
        
        #story-text {
            font-size: 1.15rem;
            line-height: 1.8;
            color: #3a2615;
            margin: 0 0 25px;
            padding-right: 20px;
            min-height: 150px;
            background-color: rgba(255, 255, 255, 0.7);
            padding: 20px;
            border-radius: 8px;
            border-left: 4px solid var(--palace-gold);
        }
        
        .button-group {
            display: grid;
            grid-template-columns: 1fr;
            gap: 15px;
            margin-top: 20px;
        }
        
        .choice-btn {
            background: linear-gradient(to bottom, #f8f4e9, #e8dfca);
            color: var(--palace-brown);
            border: 2px solid var(--palace-brown);
            padding: 16px 20px;
            border-radius: 10px;
            cursor: pointer;
            font-size: 1.05rem;
            transition: all 0.3s;
            font-family: inherit;
            text-align: left;
            position: relative;
            overflow: hidden;
        }
        
        .choice-btn:hover {
            background: linear-gradient(to bottom, #fff9e6, #f0e6c9);
            border-color: var(--palace-red);
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(139, 26, 26, 0.2);
        }
        
        .choice-btn::before {
            content: "❖";
            position: absolute;
            left: 10px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--palace-gold);
            font-size: 1.2rem;
        }
        
        .choice-btn span {
            margin-left: 25px;
            display: block;
        }
        
        #feedback-overlay {
            display: none;
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(245, 240, 230, 0.98);
            z-index: 20;
            border-radius: 15px;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 25px;
            box-sizing: border-box;
            text-align: center;
        }
        
        .feedback-content {
            max-width: 90%;
            background: white;
            border-radius: 12px;
            padding: 25px;
            border: 3px double var(--palace-brown);
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.2);
        }
        
        #feedback-title {
            font-size: 1.8rem;
            margin-bottom: 15px;
            color: var(--palace-red);
            border-bottom: 2px solid var(--palace-gold);
            padding-bottom: 10px;
        }
        
        .law-tip {
            background: #f8f9fa;
            border: 1px solid #dee2e6;
            padding: 18px;
            border-radius: 10px;
            color: #333;
            margin: 20px 0;
            line-height: 1.7;
            text-align: left;
            border-left: 4px solid var(--palace-blue);
            font-size: 0.95rem;
        }
        
        .law-tip-header {
            font-weight: bold;
            color: var(--palace-blue);
            margin-bottom: 8px;
            font-size: 1.1rem;
        }
        
        #action-btn {
            background: linear-gradient(to bottom, var(--palace-red), #6f1515);
            color: white;
            border: none;
            padding: 14px 30px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 1.1rem;
            transition: 0.3s;
            font-family: inherit;
            margin-top: 15px;
            min-width: 180px;
            border: 2px solid var(--palace-gold);
        }
        
        #action-btn:hover {
            background: linear-gradient(to bottom, #a01e1e, var(--palace-red));
            transform: translateY(-2px);
            box-shadow: 0 5px 10px rgba(139, 26, 26, 0.3);
        }
        
        .ending-screen {
            display: none;
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(245, 240, 230, 0.98);
            z-index: 30;
            border-radius: 15px;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 20px;
            box-sizing: border-box;
            text-align: center;
            overflow-y: auto;
        }
        
        .ending-content {
            max-width: 90%;
            width: 100%;
            max-height: 90vh;
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        
        .palace-seal {
            width: 100px;
            height: 100px;
            background: var(--palace-red);
            color: var(--palace-gold);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            margin: 0 auto 20px;
            border: 5px double var(--palace-gold);
            flex-shrink: 0;
        }
        
        .ending-title {
            font-size: 2rem;
            margin-bottom: 20px;
            color: var(--palace-red);
            text-align: center;
            width: 100%;
        }
        
        .ending-text {
            font-size: 1.2rem;
            line-height: 1.8;
            margin-bottom: 25px;
            text-align: center;
            width: 100%;
            max-height: 40vh;
            overflow-y: auto;
            padding: 10px 15px;
            background-color: rgba(255, 255, 255, 0.8);
            border-radius: 8px;
            border: 1px solid var(--palace-gold);
        }
        
        .ending-law-tip {
            background: #f8f9fa;
            border: 1px solid #dee2e6;
            padding: 18px;
            border-radius: 10px;
            color: #333;
            margin-bottom: 25px;
            line-height: 1.7;
            text-align: left;
            border-left: 4px solid var(--palace-blue);
            font-size: 0.95rem;
            width: 100%;
            max-height: 25vh;
            overflow-y: auto;
        }
        
        .ending-law-header {
            font-weight: bold;
            color: var(--palace-blue);
            margin-bottom: 8px;
            font-size: 1.1rem;
        }
        
        .restart-btn {
            background: linear-gradient(to bottom, var(--palace-blue), #1e4a6f);
            color: white;
            border: none;
            padding: 15px 35px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 1.2rem;
            transition: 0.3s;
            font-family: inherit;
            border: 2px solid var(--palace-gold);
            flex-shrink: 0;
        }
        
        .restart-btn:hover {
            background: linear-gradient(to bottom, #3a6f9c, var(--palace-blue));
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(44, 95, 138, 0.3);
        }
        
        @media (max-width: 600px) {
            #game-container {
                padding: 20px 15px;
            }
            
            h1 {
                font-size: 1.8rem;
            }
            
            .choice-btn {
                padding: 14px 15px 14px 40px;
            }
            
            .feedback-content {
                padding: 20px 15px;
            }
            
            .ending-title {
                font-size: 1.6rem;
            }
            
            .ending-text {
                font-size: 1.1rem;
                max-height: 45vh;
            }
            
            .ending-law-tip {
                max-height: 30vh;
            }
        }
    </style>
</head>
<body>

<div id="game-container">
    <h1>🏯 深宫普法传：凤仪天下</h1>
    <div class="subtitle">后宫浮沉，律法为尺；家国天下，法理为纲</div>
    
    <div id="stats-bar">
        <div class="stat-item">
            <div class="stat-value" id="law-score">50</div>
            <div class="stat-label">律法造诣</div>
        </div>
        <div class="stat-item">
            <div class="stat-value" id="moral-score">50</div>
            <div class="stat-label">德行声望</div>
        </div>
        <div class="stat-item">
            <div class="stat-value" id="rank">庶妃</div>
            <div class="stat-label">位分</div>
        </div>
        <div class="stat-item">
            <div class="stat-value" id="scene-counter">1</div>
            <div class="stat-label">关卡</div>
        </div>
    </div>
    
    <div id="scene-container">
        <div id="scene-decoration"></div>
        <div id="story-text"></div>
    </div>
    
    <div class="button-group" id="choices"></div>
    
    <div id="feedback-overlay">
        <div class="feedback-content">
            <div id="feedback-title"></div>
            <div class="law-tip">
                <div class="law-tip-header">律法精要</div>
                <div id="law-content"></div>
            </div>
            <button id="action-btn">继续征程</button>
        </div>
    </div>
    
    <div id="ending-screen" class="ending-screen">
        <div class="ending-content">
            <div class="palace-seal" id="ending-seal">👑</div>
            <div class="ending-title" id="ending-title"></div>
            <div class="ending-text" id="ending-text"></div>
            <div class="ending-law-tip">
                <div class="ending-law-header">律法总结</div>
                <div id="ending-law"></div>
            </div>
            <button class="restart-btn" id="restart-btn">再入深宫</button>
        </div>
    </div>
</div>

<script>
    // 游戏状态
    let currentSceneId = 'start';
    let playerStats = {
        lawScore: 50,      // 律法造诣 (0-100)
        moralScore: 50,    // 德行声望 (0-100)
        rank: 0,           // 位分等级 (0-4)
        sceneCount: 1      // 当前关卡
    };
    
    const ranks = ["庶妃", "嫔", "妃", "贵妃", "皇贵妃"];
    
    // 修复后的故事结构 - 确保每个next都指向有效场景
    const story = {
