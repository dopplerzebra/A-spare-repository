    // 根据属性决定下一个场景
    function getNextSceneBasedOnStats(option1, option2) {
        if (playerStats.lawScore >= 70 && playerStats.moralScore >= 60) {
            return option1; // 好结局路径
        } else if (playerStats.lawScore <= 30 && playerStats.moralScore <= 40) {
            return "disgrace_ending"; // 坏结局路径
        } else {
            return option2; // 普通路径
        }
    }
    
    // 检查是否触发结局
    function checkForEnding() {
        // 基于属性值的结局判定
        if (playerStats.lawScore >= 80 && playerStats.moralScore >= 80) {
            return "imperial_advisor_ending";
        } else if (playerStats.moralScore >= 85 && playerStats.lawScore >= 50) {
            return "royal_favor_ending";
        } else if (playerStats.lawScore <= 20 && playerStats.moralScore <= 20) {
            return "disgrace_ending";
        } else if (playerStats.lawScore <= 40 && playerStats.moralScore <= 40) {
            return "exile_ending";
        } else if (playerStats.sceneCount >= 8) {
            return "quiet_life_ending";
        }
        return null; // 无结局触发
    }
    
    // 更新属性显示
    function updateStatsDisplay() {
        document.getElementById('law-score').textContent = playerStats.lawScore;
        document.getElementById('moral-score').textContent = playerStats.moralScore;
        document.getElementById('rank').textContent = ranks[Math.min(playerStats.rank, ranks.length-1)];
        document.getElementById('scene-counter').textContent = playerStats.sceneCount;
    }
    
